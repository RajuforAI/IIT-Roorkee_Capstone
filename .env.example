# =============================================================================
# Telecom RAG — environment variable template (Issue #34).
#
# Single source of truth: every env var on every field of ``Settings``
# is named ``TELECOM_RAG_<FIELD_UPPER>`` — no unprefixed variants, no
# legacy names. Copy this file to ``.env`` and fill in real values.
# NEVER commit ``.env``.
# =============================================================================

# ---- LLM Providers ---------------------------------------------------------
# Primary: OpenAI. Required by the default configuration.
TELECOM_RAG_OPENAI_API_KEY=REPLACE_ME
# Fallback: Google Gemini. Optional. When set, the LLM layer routes to
# Gemini automatically if any OpenAI call fails (quota, auth, network).
# Acquire a key at https://aistudio.google.com/apikey
TELECOM_RAG_GEMINI_API_KEY=

# Comma-separated provider priority. Tokens are tried left-to-right.
# Unknown provider names are ignored. Providers whose API key is missing
# are silently dropped from the tail.
TELECOM_RAG_LLM_PROVIDER_PRIORITY=openai,gemini

# ---- Per-provider model selection -----------------------------------------
# OpenAI
TELECOM_RAG_LLM_MODEL=gpt-4o-mini
TELECOM_RAG_EMBEDDING_MODEL=text-embedding-3-small
# Gemini
TELECOM_RAG_GEMINI_MODEL=gemini-flash-lite-latest
TELECOM_RAG_GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ---- LLM retry knobs -------------------------------------------------------
# How many times to retry a single provider before falling through to the
# next. Backoff is exponential between TELECOM_RAG_LLM_RETRY_MIN_SECONDS
# and TELECOM_RAG_LLM_RETRY_MAX_SECONDS.
TELECOM_RAG_LLM_MAX_RETRIES_PER_PROVIDER=3
TELECOM_RAG_LLM_RETRY_MIN_SECONDS=1
TELECOM_RAG_LLM_RETRY_MAX_SECONDS=10

# ---- LangSmith tracing -----------------------------------------------------
# Get a key at https://smith.langchain.com → Settings → API Keys.
TELECOM_RAG_LANGCHAIN_API_KEY=REPLACE_ME
TELECOM_RAG_LANGCHAIN_TRACING_V2=true
TELECOM_RAG_LANGCHAIN_PROJECT=TeleGenie AI
TELECOM_RAG_LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ---- AWS ------------------------------------------------------------------
TELECOM_RAG_AWS_ACCESS_KEY_ID=REPLACE_ME
TELECOM_RAG_AWS_SECRET_ACCESS_KEY=REPLACE_ME
TELECOM_RAG_AWS_DEFAULT_REGION=us-east-1
TELECOM_RAG_AWS_S3_BUCKET=telecom-mvp-docs-REPLACE_ME

# ---- Application ----------------------------------------------------------
TELECOM_RAG_APP_ENV=development
TELECOM_RAG_LOG_LEVEL=INFO
TELECOM_RAG_SECRET_KEY=replace-with-random-hex

# ---- Vector store ---------------------------------------------------------
# Optional. Default is ./chroma_db
# TELECOM_RAG_CHROMA_PERSIST_DIR=./chroma_db
TELECOM_RAG_CHUNK_SIZE=1000
TELECOM_RAG_CHUNK_OVERLAP=200

# ---- Production checkpointer (Issue #11) ---------------------------------
# Optional. When set, the chat page uses PostgresSaver via
# ``get_postgres_checkpointer(...)`` instead of SqliteSaver. Required
# for multi-worker / multi-process deployments (Streamlit behind a
# load balancer, scale-out, etc.). Format is a standard psycopg DSN:
#
#   postgresql://<user>:<password>@<host>:<port>/<database>
#
# Local dev with the bundled docker-compose `postgres` service:
#
#   TELECOM_RAG_CHECKPOINT_DSN=postgresql://telecom:devpassword@postgres:5432/telecom_checkpoints
#
# Leave commented (or unset) for SqliteSaver (default).
# TELECOM_RAG_CHECKPOINT_DSN=postgresql://telecom:devpassword@postgres:5432/telecom_checkpoints

# ---- Auth DB (Issue #22 + #34) -------------------------------------------
# Path to the SQLite auth DB. Default ./auth.db — same dir as the dev
# repo root, so a clean checkout boots with an empty auth table.
#
# TELECOM_RAG_AUTH_DB=./auth.db

# Bootstrap admin password — REQUIRED ONLY on first run when the auth
# DB is empty. On first start the app creates the ``admin`` row with
# this plaintext password (bcrypt-hashed, cost factor 12). After the
# first run this env var is ignored — subsequent Streamlit restarts
# do NOT rotate the admin password, even if you change this value.
#
# To rotate the password after the first run, use the User Management
# panel on /admin (or delete auth.db and re-boot with a new password).
#
# SECURITY: Set a strong value. ``replace-me`` is rejected at startup
# as a safety check.
# TELECOM_RAG_BOOTSTRAP_ADMIN_PASSWORD=replace-me

# ---- JSONL log file (Issue #22) -------------------------------------------
# Path to the structured JSONL log file the upload / my_uploads reader
# and the auth-gate audit log both write to. Relative paths resolve
# against the process's CWD.
# TELECOM_RAG_LOG_FILE=./logs/telecom_rag.jsonl

# ---- RAGAS-in-CI offline flag (Issue #10) --------------------------------
# String-flag. Set to "1" / "true" / "yes" / "on" in .env (or shell)
# to short-circuit the ragas.evaluate call and use deterministic
# fallbacks. Used in CI to skip real OpenAI/Gemini calls.
# TELECOM_RAG_EVAL_OFFLINE=1

# ---- Cost / quota telemetry (Issue #16) ----------------------------------
# Daily USD spend cap across all agents. When unset, $10 fallback applies.
# TELECOM_RAG_COST_QUOTA_USD_DAILY=10
# Per-agent daily USD cap; a WARN log fires when an agent's daily total
# exceeds this. When unset, no per-agent cap is enforced.
# TELECOM_RAG_COST_QUOTA_USD_DAILY_BY_AGENT=3
# JSON catalog override for LLM pricing; the bundled catalog is used when
# unset. Format: {"provider/model": {"input_per_1k": 0.5, "output_per_1k": 1.5}}
# TELECOM_RAG_LLM_PRICING_JSON=
# Module path (e.g. litellm.cost_calculator) to a callable that returns
# per-token cost; the bundled pricer is used when unset.
# TELECOM_RAG_LLM_PRICER=
